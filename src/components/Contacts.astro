---
const linkObjs = [
  {
    href: "https://bsky.app/profile/remydekor.bsky.social",
    src: "/images/pictos/bluesky.svg",
    alt: "bluesky logo",
  },
  {
    href: "https://github.com/remydekor",
    src: "/images/pictos/github.svg",
    alt: "github logo",
  },
  {
    href: "https://www.linkedin.com/in/r%C3%A9my-bont%C3%A9-duval-78314482/",
    src: "/images/pictos/linkedin.svg",
    alt: "linkedin logo",
  },
  {
    href: "https://www.instagram.com/remydekor",
    src: "/images/pictos/instagram.svg",
    alt: "instagram logo",
  },
];
---

<span>
  {
    linkObjs.map((linkObj) => (
      <a href={linkObj.href} target="_blank" rel="noopener">
        <img src={linkObj.src} alt={linkObj.alt} />
      </a>
    ))
  }
</span>

<style>
  span {
    display: flex;
    gap: 0.75rem;
  }

  a {
    display: inline-block;
    height: 2.5rem;
    width: 2.5rem;
    border-radius: 50%;
    background: var(--highlight-color1);
    transition: all 0.5s;
    overflow: hidden;
  }
  a:last-child {
    margin-right: 0;
  }

  a img {
    display: block;
    fill: #fff;
    width: 100%;
    height: 100%;
  }
</style>
